# Keep the Pages repo focused on the static app.
*
!/.gitignore
!/.nojekyll
!/README.md
!/index.html
!/editor.html
!/assets/
!/assets/fonts/
!/assets/fonts/**
!/.github/
!/.github/workflows/
!/.github/workflows/pages.yml
!/year-book/
/year-book/*
!/year-book/book_app.html
!/year-book/page-flip.browser.min.js
!/year-book/assets/
!/year-book/assets/*.png
